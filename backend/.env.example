# Required environment variables for the backend
# Copy this file to .env and fill in your values

# ── PostgreSQL (Neon) ─────────────────────────────────────
# Get this from: https://neon.tech → Your project → Connection string
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── JWT ──────────────────────────────────────────────────
# Generate a random 32+ character string
JWT_SECRET=change_this_to_a_random_secret_32chars

# ── Email (for OTP) ───────────────────────────────────────
# Use a Gmail address with an App Password (NOT your regular password)
# Enable at: https://myaccount.google.com/apppasswords
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── CORS ─────────────────────────────────────────────────
# Your deployed frontend URL (Vercel/Netlify)
FRONTEND_URL=https://your-site.vercel.app

# ── Server Port ───────────────────────────────────────────
PORT=4000

# ── Environment ───────────────────────────────────────────
NODE_ENV=production
